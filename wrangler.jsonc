{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "websites",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".",
    "exclude": ["node_modules", "server.js", "_private_admin", "data", "package-lock.json"]
  },
  "observability": {
    "enabled": true
  }
}
